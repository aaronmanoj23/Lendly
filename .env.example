SECRET_KEY=replace-me-with-django-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres
DB_NAME=lendly
DB_USER=lendly
DB_PASSWORD=lendly
DB_HOST=db
DB_PORT=5432

# Email (console backend by default; swap for SMTP in prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@lendly.local

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# AWS S3 (optional; falls back to local media if blank)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-west-1

# Google Vision (path to service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json

# eBay
EBAY_APP_ID=
